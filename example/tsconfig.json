{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "**/*",
    "**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@ldesign/router": ["../src"]
    },
    "types": [
      "vite/client"
    ],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false
  }
}